# 1. . — любой символ

import re
print(re.findall("c.t", "cat cot cut"))


# 2. * — 0 или больше повторений

print(re.findall("ab*", "a ab abb abbb"))


# 3. + — 1 или больше

print(re.findall("ab+", "a ab abb abbb"))


# 4. ^ — начало строки

print(re.findall("^Hello", "Hello world"))


# 5. [] — набор символов

print(re.findall("[aeiou]", "hello world"))
